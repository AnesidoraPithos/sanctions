# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API Keys
USA_TRADE_GOV_API_KEY=your_api_key_here
OPENAI_API_KEY=your_openai_key_here
WHALEWISDOM_API_KEY=your_whalewisdom_api_key_here

# Database
DATABASE_PATH=../sanctions.db

# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Research Configuration
FUZZY_THRESHOLD_DEFAULT=80
MAX_SEARCH_RESULTS=100
REQUEST_TIMEOUT=60  # seconds - increased for parallel searches (was 30)
MAX_LEVEL_2_SEARCHES=20  # Maximum subsidiaries to search for level 2 (prevents timeout)
MAX_LEVEL_3_SEARCHES=10  # Maximum subsidiaries to search for level 3 (prevents timeout)

# Parallelization Settings (Phase 2 Performance)
MAX_PARALLEL_SUBSIDIARY_SEARCHES=10  # Max concurrent subsidiary API searches
MAX_PARALLEL_SANCTIONS_SCREENING=20  # Max concurrent sanctions screenings

# Feature Flags (Phase 2+)
ENABLE_NETWORK_TIER=False
ENABLE_DEEP_TIER=False
